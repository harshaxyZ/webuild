// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model User {
  id            String       @id @default(cuid())
  email         String       @unique
  name          String?
  phoneNumber   String?
  passwordHash  String?
  emailVerified DateTime?
  phoneVerified DateTime?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  submissions   Submission[]
}

model Submission {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id])
  ideaDescription String?
  socialLinks     String?
  status          String   @default("SUBMITTED") // SUBMITTED, IN_PROGRESS, DEMO_READY, COMPLETED
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  uploads         Upload[]
}

model Upload {
  id           String     @id @default(cuid())
  submissionId String
  submission   Submission @relation(fields: [submissionId], references: [id])
  fileUrl      String
  fileType     String
  fileName     String
  createdAt    DateTime   @default(now())
}

model Admin {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String
  passwordHash String
  role         String   @default("ADMIN") // ADMIN, SUPERADMIN
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Invite {
  id        String   @id @default(cuid())
  email     String   @unique
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  usedAb    Boolean  @default(false)
}

model OtpRecord {
  id        String   @id @default(cuid())
  medium    String   // EMAIL, PHONE
  target    String   // the email address or phone number
  otpHash   String
  expiresAt DateTime
  createdAt DateTime @default(now())
  used      Boolean  @default(false)
}
